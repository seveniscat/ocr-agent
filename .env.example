# Copy to .env and adjust. All keys are optional (sensible defaults in app/config.py).

# ---- Tiling (high-res handling) ----
# Tile long-edge target in px. Larger = fewer tiles + more VRAM per tile.
OCR_TILE_TARGET_SIZE=1600
# Overlap ratio between adjacent tiles (0..0.5). Prevents splitting glyphs/lines.
OCR_TILE_OVERLAP=0.15
# Images with both dims below this skip tiling entirely (fast path).
OCR_SMALL_IMAGE_THRESHOLD=2000

# ---- OCR (PaddleOCR) ----
# Detection box threshold (lower = more boxes, more noise).
OCR_OCR_THRESHOLD=0.3
# Recognition confidence below which we route the crop to the VLM.
OCR_REC_CONFIDENCE_FALLBACK=0.6

# ---- VLM fallback (art / curved text) ----
OCR_VLM_ENABLED=true
OCR_VLM_PROVIDER=qwen
OCR_VLM_API_KEY=
OCR_VLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OCR_VLM_MODEL=qwen-vl-max

# ---- Async task handling ----
# Images with the long edge above this are processed asynchronously (202 + task_id).
OCR_LARGE_IMAGE_THRESHOLD=4000
