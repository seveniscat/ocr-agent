# Copy to .env and adjust. All keys are optional (sensible defaults in app/config.py).

# ---- Tiling (v1: long edge ≤ 4000px → single PaddleOCR predict, no grid) ----
# Tile size when long edge exceeds small_image_threshold (future >4000px path).
OCR_TILE_TARGET_SIZE=4000
# Overlap ratio between adjacent tiles (only used when tiling kicks in).
OCR_TILE_OVERLAP=0.15
# Cross-tile dedupe thresholds (px); rarely needed when single-tile.
OCR_TILE_MERGE_X_THRES=50
OCR_TILE_MERGE_Y_THRES=35
# Long edge ≤ this → skip tiling (default matches OCR_LARGE_IMAGE_THRESHOLD).
OCR_SMALL_IMAGE_THRESHOLD=4000

# ---- OCR detection tuning (DB++ text detector) ----
# Pixel probability threshold for the shrink map.
# Lower = more boxes (recall up, art-text fishing) at the cost of more noise.
OCR_OCR_THRESHOLD=0.3
# Min average score inside a candidate box. Lower = keeps faint art text.
OCR_OCR_BOX_THRESH=0.6
# Expand each detected box by this ratio. Larger = looser boxes for art text.
OCR_OCR_UNCLIP_RATIO=1.8
# DB detector resizes the long edge to this before inference.
# 1216 = PaddleOCR 3.x recommendation for higher-res single-tile inputs.
OCR_OCR_DET_LIMIT_SIDE_LEN=1216
# max = scale down only (keep detail); min = scale up only (faster on large images).
OCR_OCR_DET_LIMIT_TYPE=max
# Recognition confidence below which VLM may re-read the crop (only when fallback enabled).
OCR_REC_CONFIDENCE_FALLBACK=0.6
# PP-OCRv6 single-model multilingual rec; lang=ch is the recommended default.
OCR_OCR_VERSION=PP-OCRv6
OCR_OCR_LANG=ch

# ---- Output granularity (box level) ----
# word      = per-token boxes (PaddleOCR return_word_box)
# line      = default text-line boxes (most common)           ★ default
# paragraph = line boxes merged into paragraph blocks by
#             geometric proximity (good for packaging copy blocks)
OCR_OCR_GRANULARITY=line
# [paragraph mode] Two lines merge when vertical gap <= ratio * avg line height.
OCR_OCR_PARAGRAPH_GAP_RATIO=0.6
# [paragraph mode] Min horizontal x-range overlap ratio to merge two lines.
OCR_OCR_PARAGRAPH_X_OVERLAP=0.3

# ---- VLM (opt-in cloud vision; OCR /analyze is PaddleOCR-only by default) ----
# Also used by /understand, /agent, /panels/vlm when enabled.
# NOTE: qwen-vl-max / qwen-vl-plus are scheduled for deprecation on 2026-07-13
# (DashScope notice 118178). Default model is now qwen3.7-plus.
OCR_VLM_ENABLED=false
# Re-read low-confidence OCR crops during POST /analyze (requires VLM_ENABLED + key).
OCR_VLM_OCR_FALLBACK_ENABLED=false
OCR_VLM_PROVIDER=qwen
OCR_VLM_API_KEY=
OCR_VLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OCR_VLM_MODEL=qwen3.7-plus
# Qwen3.x thinking mode (deep reasoning before answering). Off by default: it's
# incompatible with response_format=json_object, so JSON output relies on our
# tolerant parser when enabled. Turn on for QA-reasoning tasks.
OCR_VLM_ENABLE_THINKING=false

# ---- AI Native understanding layer (POST /understand) ----
# The VLM looks at the whole image and answers "what is this" (category / style /
# salient elements). Level-1 = one whole-image VLM call. Disable if you don't
# want any whole-image VLM calls.
OCR_UNDERSTAND_ENABLED=false
# Long edge (px) the image is downscaled to before asking the VLM. Dielines run
# 1000-10000px but VLMs effectively resolve ~2Kpx; for "what is this" a single
# downscale is enough. Larger = sharper but more tokens.
OCR_UNDERSTAND_MAX_SIDE=1080

# ---- AI Native agent layer (POST /agent/understand) ----
# The agent: qwen3-max reasons + calls look/ocr_text/describe tools over a ReAct
# loop. The brain never sees pixels — it inspects the image via tool outputs.
OCR_AGENT_LLM_MODEL=qwen3-max
OCR_AGENT_VLM_MODEL=qwen3.7-plus
OCR_AGENT_MAX_ROUNDS=8
OCR_AGENT_LOOK_MAX_SIDE=1080

# ---- Panel splitting (VLM cut-line detection) ----
# Long edge the image is downscaled to before the VLM finds cut lines. Cut
# lines are a low-detail task (just outlines), so 512 is enough and fast.
OCR_PANELS_VLM_MAX_SIDE=512

# ---- Copy verification (POST /verify; deterministic rules, no cloud model) ----
# Compare OCR'd text against a caller-supplied standard-copy list. The metric is
# recall (fraction of a standard entry's chars found, in order, in the OCR text).
# recall ≥ MATCH → matched; ≥ PARTIAL (but < MATCH) → partial; else missing.
# No enable switch: the path is fully local (no API key/cost), always on like /analyze.
OCR_VERIFY_MATCH_THRESHOLD=0.85
OCR_VERIFY_PARTIAL_THRESHOLD=0.60

# ---- Preprocessing (die-line auto-crop) ----
# Crop blank margins around the die-line artwork before OCR.
# Disable for non-die-line images, or when the original frame must be kept.
OCR_PREPROCESS_AUTOCROP=true
# Grayscale cutoff for "ink" pixels (background is near-white). Lower = stricter
# (only dark ink counts, ignores faint scan noise); higher = more aggressive.
OCR_PREPROCESS_AUTOCROP_THRESHOLD=240
# Extra margin (px) kept on every side after cropping.
OCR_PREPROCESS_AUTOCROP_PADDING=0

# ---- Async task handling ----
# Images with the long edge above this are processed asynchronously (202 + task_id).
OCR_LARGE_IMAGE_THRESHOLD=4000

# ---- URL input (url form field) ----
# Every image endpoint accepts either a multipart `file` OR a `url` form field.
# These bound the URL download so a slow/huge URL can't hang or OOM the service.
# Connect/read timeout in seconds.
OCR_URL_FETCH_TIMEOUT=30
# Abort the download once the body exceeds this size (bytes). 100MB default —
# die-line images can be large.
OCR_URL_FETCH_MAX_BYTES=104857600
